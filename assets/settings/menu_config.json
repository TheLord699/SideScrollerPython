{
  "menus": {
    "main": {
      "music": "main",
      "background": "assets/maps/LayerTest",
      "lighting": false,
      "elements": [
        {
          "type": "label",
          "id": "version",
          "anchor": [0.0, 0.0],
          "offset": [-30, -20],
          "width": 200,
          "height": 100,
          "label": "ver: {game.version}",
          "font": "fantasy",
          "font_size": 16,
          "render_order": 0
        },
        {
          "type": "label",
          "id": "title",
          "anchor": [0.5, 0.0],
          "offset": [0, 150],
          "width": 200,
          "height": 100,
          "label": "Generic Side Scroller",
          "font": "fantasy",
          "font_size": 28,
          "render_order": 0,
          "centered": true
        },
        {
          "type": "button",
          "id": "play_button",
          "anchor": [0.5, 0.417],
          "offset": [0, 0],
          "width": 200,
          "height": 100,
          "centered": true,
          "sprite_sheet": "assets/sprites/gui/ui.png",
          "sprite_id": [33, 0],
          "sprite_width": 95,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "label": "Play",
          "font": "fantasy",
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "callback": "change_menu:select_menu",
          "render_order": 0
        },
        {
          "type": "button",
          "id": "settings_button",
          "anchor": [0.5, 0.667],
          "offset": [0, 0],
          "width": 200,
          "height": 100,
          "centered": true,
          "sprite_sheet": "assets/sprites/gui/ui.png",
          "sprite_id": [33, 0],
          "sprite_width": 95,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "label": "Settings",
          "font": "fantasy",
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "callback": "change_menu:settings",
          "render_order": 0
        }
      ]
    },
    "select_menu": {
      "elements": [
        {
          "type": "button",
          "id": "new_game_button",
          "anchor": [0.5, 0.417],
          "offset": [0, 0],
          "width": 200,
          "height": 100,
          "centered": true,
          "sprite_sheet": "assets/sprites/gui/ui.png",
          "sprite_id": [33, 0],
          "sprite_width": 95,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "label": "New Game",
          "font": "fantasy",
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "callback": "call:start_game:TestMap",
          "render_order": 0
        },
        {
          "type": "button",
          "id": "load_button",
          "anchor": [0.5, 0.667],
          "offset": [0, 0],
          "width": 200,
          "height": 100,
          "centered": true,
          "sprite_sheet": "assets/sprites/gui/ui.png",
          "sprite_id": [33, 0],
          "sprite_width": 95,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "label": "Load Game",
          "font": "fantasy",
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "callback": "call:load_game",
          "render_order": 0
        },
        {
          "type": "button",
          "id": "back_button",
          "anchor": [0.143, 0.833],
          "offset": [0, 0],
          "width": 100,
          "height": 100,
          "centered": true,
          "sprite_sheet": "assets/sprites/gui/ui.png",
          "sprite_id": [0, 0],
          "sprite_width": 32,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "callback": "change_menu:main",
          "render_order": 0
        }
      ]
    },
    "settings": {
      "elements": [
        {
          "type": "label",
          "id": "volume_text",
          "anchor": [0.5, 0.2],
          "offset": [0, 0],
          "label": "Volume",
          "font": "fantasy"
        },
        {
          "type": "slider",
          "id": "volume_slider",
          "anchor": [0.5, 0.283],
          "offset": [-100, 0],
          "width": 200,
          "height": 20,
          "min_value": 0.0,
          "max_value": 1.1,
          "initial_value": "game_context.volume",
          "step_size": 0.01,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "variable": "update_slider:volume_slider"
        },
        {
          "type": "dynamic_button",
          "id": "indicator_button",
          "anchor": [0.5, 0.45],
          "offset": [110, 0],
          "width": 200,
          "height": 100,
          "centered": true,
          "sprite_sheet": "assets/sprites/gui/ui.png",
          "sprite_id": [33, 0],
          "sprite_width": 95,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "font": "fantasy",
          "font_size": 16,
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "label": "Indicators: {show_indicators?On:Off}",
          "callback": "toggle:show_indicators",
          "render_order": 0
        },
        {
          "type": "dynamic_button",
          "id": "particle_button",
          "anchor": [0.5, 0.45],
          "offset": [-110, 0],
          "width": 200,
          "height": 100,
          "centered": true,
          "sprite_sheet": "assets/sprites/gui/ui.png",
          "sprite_id": [33, 0],
          "sprite_width": 95,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "font": "fantasy",
          "font_size": 16,
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "label": "Particles: {particles.enable_particles?On:Off}",
          "callback": "toggle:particles.enable_particles",
          "render_order": 0
        },
        {
          "type": "dynamic_button",
          "id": "foreground_button",
          "anchor": [0.5, 0.658],
          "offset": [-110, 0],
          "width": 200,
          "height": 100,
          "centered": true,
          "sprite_sheet": "assets/sprites/gui/ui.png",
          "sprite_id": [33, 0],
          "sprite_width": 95,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "font": "fantasy",
          "font_size": 16,
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "label": "Foreground: {foreground.enable_foreground?On:Off}",
          "callback": "toggle:foreground.enable_foreground",
          "render_order": 0
        },
        {
          "type": "dynamic_button",
          "id": "cam_follow_mouse_button",
          "anchor": [0.5, 0.658],
          "offset": [110, 0],
          "width": 200,
          "height": 100,
          "centered": true,
          "sprite_sheet": "assets/sprites/gui/ui.png",
          "sprite_id": [33, 0],
          "sprite_width": 95,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "font": "fantasy",
          "font_size": 16,
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "label": "Cam Follow Mouse?: {player.enable_cam_mouse?On:Off}",
          "callback": "toggle:player.enable_cam_mouse",
          "render_order": 0
        },
        {
          "type": "dynamic_button",
          "id": "vigorous_optimizations_button",
          "anchor": [0.5, 0.867],
          "offset": [0, 0],
          "width": 250,
          "height": 100,
          "centered": true,
          "sprite_sheet": "assets/sprites/gui/ui.png",
          "sprite_id": [33, 0],
          "sprite_width": 95,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "font": "fantasy",
          "font_size": 16,
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "label": "Vigorous Optimizations?: {vigorous_optimizations?On:Off}",
          "callback": "toggle:vigorous_optimizations",
          "render_order": 0
        },
        {
          "type": "label",
          "id": "message",
          "anchor": [0.68, 0.77],
          "width": 250,
          "height": 100,
          "font_size": 15,
          "label": "TEMPORARY DEV NOTE:\nVIGOROUS OPTIMIZATIONS\nWILL STOP ALL UPDATES\nFOR ENTITIES AND PROJECTILES\nAS SOON AS THEY ARE OFF-SCREEN,\nWHICH CAN GREATLY IMPROVE PERFORMANCE\nBUT MAY AFFECT REALISM",
          "render_order": 0
        },
        {
          "type": "button",
          "id": "back_button",
          "anchor": [0.143, 0.833],
          "offset": [0, 0],
          "width": 100,
          "height": 100,
          "centered": true,
          "sprite_sheet": "assets/sprites/gui/ui.png",
          "sprite_id": [0, 0],
          "sprite_width": 32,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "callback": "change_menu:main",
          "render_order": 0
        }
      ]
    },
    "death": {
      "elements": [
        {
          "type": "label",
          "id": "Death_message",
          "anchor": [0.5, 0.35],
          "offset": [0, 0],
          "width": 200,
          "height": 100,
          "label": "You Died",
          "font": "fantasy",
          "font_size": 35,
          "render_order": 0,
          "centered": true
        },
        {
          "type": "button",
          "id": "restart_button",
          "anchor": [0.5, 0.583],
          "offset": [0, 0],
          "width": 200,
          "height": 100,
          "centered": true,
          "sprite_sheet": "assets/sprites/gui/ui.png",
          "sprite_id": [33, 0],
          "sprite_width": 95,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "label": "Restart",
          "font": "fantasy",
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "callback": "call:restart_game",
          "render_order": 0
        }
      ]
    }
  }
}