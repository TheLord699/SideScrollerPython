{
  "menus": {
    "main": {
      "music": "main",
      "background": "assets/maps/LayerTest",
      "lighting": false,
      "elements": [
        {
          "type": "label",
          "id": "version",
          "x": -40,
          "y": -30,
          "width": 200,
          "height": 100,
          "label": "ver: {game.version}",
          "font": "fantasy",
          "font_size": 16,
          "render_order": 0
        },
        {
          "type": "label",
          "id": "title",
          "x": "screen_width/2.6",
          "y": 100,
          "width": 200,
          "height": 100,
          "label": "Generic Side Scroller",
          "font": "fantasy",
          "font_size": 28,
          "render_order": 0
        },
        {
          "type": "button",
          "id": "play_button",
          "x": "screen_width/2",
          "y": 250,
          "width": 200,
          "height": 100,
          "centered": true,
          "sprite_sheet": "ui_sheet",
          "sprite_id": [33, 0],
          "sprite_width": 95,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "label": "Play",
          "font": "fantasy",
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "callback": "change_menu:select_menu",
          "render_order": 0
        },
        {
          "type": "button",
          "id": "settings_button",
          "x": "screen_width/2",
          "y": 400,
          "width": 200,
          "height": 100,
          "centered": true,
          "sprite_sheet": "ui_sheet",
          "sprite_id": [33, 0],
          "sprite_width": 95,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "label": "Settings",
          "font": "fantasy",
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "callback": "change_menu:settings",
          "render_order": 0
        }
      ]
    },

    "select_menu": {
      "elements": [
        {
          "type": "button",
          "id": "new_game_button",
          "x": "screen_width/2",
          "y": 250,
          "width": 200,
          "height": 100,
          "centered": true,
          "sprite_sheet": "ui_sheet",
          "sprite_id": [33, 0],
          "sprite_width": 95,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "label": "New Game",
          "font": "fantasy",
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "callback": "call:start_game:TestMap",
          "render_order": 0
        },
        {
          "type": "button",
          "id": "load_button",
          "x": "screen_width/2",
          "y": 400,
          "width": 200,
          "height": 100,
          "centered": true,
          "sprite_sheet": "ui_sheet",
          "sprite_id": [33, 0],
          "sprite_width": 95,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "label": "Load Game",
          "font": "fantasy",
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "callback": "call:load_game",
          "render_order": 0
        },
        {
          "type": "button",
          "id": "back_button",
          "x": "screen_width/7",
          "y": 500,
          "width": 100,
          "height": 100,
          "centered": true,
          "sprite_sheet": "ui_sheet",
          "sprite_id": [0, 0],
          "sprite_width": 32,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "callback": "change_menu:main",
          "render_order": 0
        }
      ]
    },

    "settings": {
      "elements": [
        {
          "type": "label",
          "id": "volume_text",
          "x": "screen_width/2",
          "y": 120,
          "label": "Volume",
          "font": "fantasy"
        },
        {
          "type": "slider",
          "id": "volume_slider",
          "x": "screen_width/2.65",
          "y": 170,
          "width": 200,
          "height": 20,
          "min_value": 0.0,
          "max_value": 1.1,
          "initial_value": "env.volume",
          "step_size": 0.01,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "variable": "update_slider:volume_slider"
        },
        {
          "type": "dynamic_button",
          "id": "indicator_button",
          "x": "screen_width/2+110",
          "y": 270,
          "width": 200,
          "height": 100,
          "centered": true,
          "sprite_sheet": "ui_sheet",
          "sprite_id": [33, 0],
          "sprite_width": 95,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "font": "fantasy",
          "font_size": 16,
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "label": "Indicators: {show_indicators?On:Off}",
          "callback": "toggle:show_indicators",
          "render_order": 0
        },
        {
          "type": "dynamic_button",
          "id": "particle_button",
          "x": "screen_width/2-110",
          "y": 270,
          "width": 200,
          "height": 100,
          "centered": true,
          "sprite_sheet": "ui_sheet",
          "sprite_id": [33, 0],
          "sprite_width": 95,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "font": "fantasy",
          "font_size": 16,
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "label": "Particles: {particles.enable_particles?On:Off}",
          "callback": "toggle:particles.enable_particles",
          "render_order": 0
        },
        {
          "type": "dynamic_button",
          "id": "foreground_button",
          "x": "screen_width/2-110",
          "y": 395,
          "width": 200,
          "height": 100,
          "centered": true,
          "sprite_sheet": "ui_sheet",
          "sprite_id": [33, 0],
          "sprite_width": 95,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "font": "fantasy",
          "font_size": 16,
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "label": "Foreground: {foreground.enable_foreground?On:Off}",
          "callback": "toggle:foreground.enable_foreground",
          "render_order": 0
        },
        {
          "type": "dynamic_button",
          "id": "cam_follow_mouse_button",
          "x": "screen_width/2+110",
          "y": 395,
          "width": 200,
          "height": 100,
          "centered": true,
          "sprite_sheet": "ui_sheet",
          "sprite_id": [33, 0],
          "sprite_width": 95,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "font": "fantasy",
          "font_size": 16,
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "label": "Cam Follow Mouse?: {player.enable_cam_mouse?On:Off}",
          "callback": "toggle:player.enable_cam_mouse",
          "render_order": 0
        },
        {
          "type": "dynamic_button",
          "id": "vigorous_optimizations_button",
          "x": "screen_width/2",
          "y": 520,
          "width": 250,
          "height": 100,
          "centered": true,
          "sprite_sheet": "ui_sheet",
          "sprite_id": [33, 0],
          "sprite_width": 95,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "font": "fantasy",
          "font_size": 16,
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "label": "Vigorous Optimizations?: {vigorous_optimizations?On:Off}",
          "callback": "toggle:vigorous_optimizations",
          "render_order": 0
        },
        {
          "type": "label",
          "id": "message",
          "x": "screen_width/2+132",
          "y": 470,
          "centered": true,
          "width": 250,
          "height": 100,
          "font_size": 15,
          "label": "TEMPORARY DEV NOTE:\nVIGOROUS OPTIMIZATIONS\nWILL STOP ALL UPDATES\nFOR ENTITIES AND PROJECTILES\nAS SOON AS THEY ARE OFF-SCREEN,\nWHICH CAN GREATLY IMPROVE PERFORMANCE\nBUT MAY AFFECT REALISM",
          "render_order": 0
        },
        {
          "type": "button",
          "id": "back_button",
          "x": "screen_width/7",
          "y": 500,
          "width": 100,
          "height": 100,
          "centered": true,
          "sprite_sheet": "ui_sheet",
          "sprite_id": [0, 0],
          "sprite_width": 32,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "callback": "change_menu:main",
          "render_order": 0
        }
      ]
    },

    "death": {
      "elements": [
        {
          "type": "label",
          "id": "Death_message",
          "x": "screen_width/2.6",
          "y": 150,
          "width": 200,
          "height": 100,
          "label": "You Died",
          "font": "fantasy",
          "font_size": 35,
          "render_order": 0
        },
        {
          "type": "button",
          "id": "restart_button",
          "x": "screen_width/2",
          "y": 350,
          "width": 200,
          "height": 100,
          "centered": true,
          "sprite_sheet": "ui_sheet",
          "sprite_id": [33, 0],
          "sprite_width": 95,
          "sprite_height": 32,
          "alpha": true,
          "scale_multiplier": 1.1,
          "label": "Restart",
          "font": "fantasy",
          "hover_range": 3.5,
          "click_sound": "assets/sounds/ui/01_chest_open_4.wav",
          "click_sound_volume": 2.0,
          "callback": "call:game.environment.restart_game",
          "render_order": 0
        }
      ]
    }
  }
}